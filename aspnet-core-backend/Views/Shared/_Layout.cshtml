<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nile Health MVC Portal</title>
    <!-- Tailwind CSS CDN for pristine, high-fidelity responsive styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        .font-mono {
            font-family: 'JetBrains Mono', monospace;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen flex flex-col">
    <!-- Navigation Bar -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-3">
                    <div class="bg-sky-500 text-white p-2.5 rounded-xl font-bold text-sm tracking-wider font-mono">
                        NH
                    </div>
                    <span class="text-xl font-bold tracking-tight text-slate-900">
                        Nile Health <span class="text-sky-500 font-medium text-xs font-mono uppercase bg-sky-50 px-2 py-0.5 rounded ml-1 border border-sky-100">MVC</span>
                    </span>
                </div>
                <nav class="hidden md:flex space-x-8 text-sm font-medium text-slate-600">
                    <a href="/" class="hover:text-sky-600 transition-colors">Home Landing</a>
                    <a href="/Home/Dashboard" class="hover:text-sky-600 transition-colors">Interactive Dashboard</a>
                </nav>
                <div class="flex items-center gap-4">
                    <a href="/Home/Dashboard" class="inline-flex items-center justify-center px-4 py-2 text-xs font-semibold text-white bg-slate-900 hover:bg-slate-800 rounded-xl transition-all shadow-sm">
                        Enter Dashboard
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content Stage -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
        @RenderBody()
    </main>

    <!-- Professional Aesthetic Footer -->
    <footer class="bg-white border-t border-slate-200 mt-auto py-6">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-xs text-slate-500">
                &copy; 2026 Nile Health. All Rights Reserved. Fully backed by ASP.NET Core 8.0 & Firestore db.
            </p>
            <div class="flex gap-4 text-xs text-slate-400">
                <span class="hover:text-slate-600 cursor-pointer">Security Protocol</span>
                <span>•</span>
                <span class="hover:text-slate-600 cursor-pointer">Terms of Service</span>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
