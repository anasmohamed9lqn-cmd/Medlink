@{
    ViewData["Title"] = "System Administration & Health Overview";
    var doctors = ViewBag.Doctors as List<User> ?? new List<User>();
    var patients = ViewBag.Patients as List<User> ?? new List<User>();
    var insuranceUsers = ViewBag.InsuranceUsers as List<User> ?? new List<User>();
    var institutions = ViewBag.Institutions as List<MedicalInstitution> ?? new List<MedicalInstitution>();
    var organizationRequests = ViewBag.OrganizationRequests as List<OrganizationRequest> ?? new List<OrganizationRequest>();
}

<div class="space-y-8 py-4">
    <!-- Top Dashboard Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-slate-200 pb-5">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-slate-900">System Directory Dashboard</h1>
            <p class="text-xs text-slate-500 mt-1">Live data streams from Firebase Firestore mapped to C# MVC Models</p>
        </div>
        <div class="text-[11px] font-mono font-bold text-slate-400 uppercase tracking-wider bg-slate-100 px-3 py-1.5 rounded-lg border border-slate-200">
            Database ID: <span class="text-sky-600">ai-studio-51b0b46c-80ba-47ad-8a0c-dc4a7d8c59c7</span>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="bg-red-50 border border-red-200 text-red-800 p-4 rounded-xl text-xs font-mono">
            ⚠️ @ViewBag.Error
        </div>
    }

    <!-- Statistical Bento Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Doctors -->
        <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
            <span class="text-[9px] font-mono font-black text-slate-400 uppercase tracking-wider block">Registered Doctors</span>
            <div class="text-2xl font-bold text-slate-900 font-mono mt-1">@doctors.Count</div>
            <div class="text-[10px] text-emerald-600 font-medium mt-1">● Fully Licensed</div>
        </div>

        <!-- Patients -->
        <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
            <span class="text-[9px] font-mono font-black text-slate-400 uppercase tracking-wider block">Patients Tracked</span>
            <div class="text-2xl font-bold text-slate-900 font-mono mt-1">@patients.Count</div>
            <div class="text-[10px] text-slate-450 font-normal mt-1">Self-managed medical ids</div>
        </div>

        <!-- Insurance Providers -->
        <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
            <span class="text-[9px] font-mono font-black text-slate-400 uppercase tracking-wider block">Insurers Mapped</span>
            <div class="text-2xl font-bold text-slate-900 font-mono mt-1">@insuranceUsers.Count</div>
            <div class="text-[10px] text-sky-600 font-medium mt-1">Outpatient claims coverage</div>
        </div>

        <!-- Institutions -->
        <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
            <span class="text-[9px] font-mono font-black text-slate-400 uppercase tracking-wider block">Institutions Registered</span>
            <div class="text-2xl font-bold text-slate-900 font-mono mt-1">@institutions.Count</div>
            <div class="text-[10px] text-slate-500 font-normal mt-1">Hospitals & Labs</div>
        </div>
    </div>

    <!-- Active Registered Users Directory -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="p-5 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
            <div>
                <h2 class="text-sm font-bold text-slate-900">User Directory</h2>
                <p class="text-[11px] text-slate-500 mt-0.5">Clinical accounts registered within the platform</p>
            </div>
            <span class="text-[10px] font-mono bg-sky-50 text-sky-700 px-2 py-1 rounded border border-sky-100">Live Firebase Data</span>
        </div>
        
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-100 text-left text-xs">
                <thead class="bg-slate-50 text-slate-400 font-semibold text-[10px] uppercase font-mono tracking-wider">
                    <tr>
                        <th class="px-6 py-3">Full Name</th>
                        <th class="px-6 py-3">Role</th>
                        <th class="px-6 py-3">Email Address</th>
                        <th class="px-6 py-3">Phone</th>
                        <th class="px-6 py-3">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 bg-white text-slate-700">
                    @foreach (var user in (ViewBag.Users as List<User> ?? new List<User>()))
                    {
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="px-6 py-4 font-bold text-slate-900">@user.FullName</td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-0.5 rounded text-[10px] font-bold font-mono uppercase border 
                                    @(user.Role == "admin" ? "bg-purple-50 border-purple-100 text-purple-700" : 
                                      user.Role == "doctor" ? "bg-emerald-50 border-emerald-100 text-emerald-700" :
                                      user.Role == "insurance" ? "bg-amber-50 border-amber-100 text-amber-700" : 
                                      "bg-sky-50 border-sky-100 text-sky-700")">
                                    @user.Role
                                </span>
                            </td>
                            <td class="px-6 py-4 font-mono">@user.Email</td>
                            <td class="px-6 py-4">@(string.IsNullOrEmpty(user.Phone) ? "N/A" : user.Phone)</td>
                            <td class="px-6 py-4">
                                <span class="px-1.5 py-0.5 rounded-full text-[9px] font-bold tracking-wide uppercase
                                    @(user.Status == "Active" || user.Status == "approved" ? "bg-emerald-100 text-emerald-800" : 
                                      user.Status == "Pending" || user.Status == "pending" ? "bg-amber-100 text-amber-800" : 
                                      "bg-rose-100 text-rose-800")">
                                    @(string.IsNullOrEmpty(user.Status) ? "Active" : user.Status)
                                </span>
                            </td>
                        </tr>
                    }
                    @if (!(ViewBag.Users as List<User> ?? new List<User>()).Any())
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-slate-400 font-mono">
                                No registered accounts found in Google Firestore.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Medical Institutions -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden flex flex-col">
            <div class="p-5 border-b border-slate-100 bg-slate-50/50">
                <h3 class="text-sm font-bold text-slate-900">Medical Institutions</h3>
                <p class="text-[11px] text-slate-500 mt-0.5">Hospitals and laboratories in NileHealth</p>
            </div>
            <div class="p-4 flex-grow overflow-y-auto max-h-96">
                <div class="space-y-3">
                    @foreach (var inst in institutions)
                    {
                        <div class="p-3 bg-slate-50 border border-slate-200 rounded-xl flex items-center justify-between gap-4">
                            <div>
                                <p class="text-xs font-bold text-slate-900">@inst.Name</p>
                                <p class="text-[10px] text-slate-450 mt-0.5">Location: @inst.Location • Type: @inst.Type</p>
                            </div>
                            <span class="text-[9px] font-mono font-bold bg-slate-200 text-slate-600 px-1.5 py-0.5 rounded">
                                @inst.Code
                            </span>
                        </div>
                    }
                    @if (!institutions.Any())
                    {
                        <p class="text-xs text-slate-400 font-mono text-center py-8">No registered medical institutions.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Organization Join Requests -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden flex flex-col">
            <div class="p-5 border-b border-slate-100 bg-slate-50/50">
                <h3 class="text-sm font-bold text-slate-900">Organization Requests</h3>
                <p class="text-[11px] text-slate-500 mt-0.5">Pending validation for clinical institutions</p>
            </div>
            <div class="p-4 flex-grow overflow-y-auto max-h-96">
                <div class="space-y-3">
                    @foreach (var req in organizationRequests)
                    {
                        <div class="p-3 bg-white border border-slate-200 rounded-xl flex items-start justify-between gap-4">
                            <div>
                                <p class="text-xs font-bold text-slate-900">@req.Name</p>
                                <p class="text-[10px] text-slate-450 mt-0.5 font-mono">Code: @req.Code | Type: @req.Type</p>
                                <p class="text-[10px] text-slate-500 mt-1">📍 @req.Location</p>
                            </div>
                            <span class="text-[9px] font-bold tracking-wide uppercase px-2 py-0.5 rounded-full 
                                @(req.Status == "pending" ? "bg-amber-100 text-amber-800" : "bg-emerald-100 text-emerald-800")">
                                @req.Status
                            </span>
                        </div>
                    }
                    @if (!organizationRequests.Any())
                    {
                        <p class="text-xs text-slate-400 font-mono text-center py-8">No pending organization join requests.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
